# محطة أبو أحمد - ملف الإعدادات
# انسخ هذا الملف إلى .env وأضف مفاتيحك الفعلية

# مفتاح Gemini API - احصل عليه من: https://aistudio.google.com/app/apikey
# لا تضع المفتاح مباشرة في الكود! استخدم هذا الملف فقط
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# إعدادات التوقيع (للـ CI/CD فقط)
STORE_PASSWORD=
KEY_ALIAS=
KEY_PASSWORD=
